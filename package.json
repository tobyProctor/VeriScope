{
  "name": "block-diagram-viewer",
  "displayName": "Block Diagram Viewer",
  "description": "View Verilator XML hierarchy diagrams and jump to source in VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:blockDiagram.openSchematic"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "blockDiagram.openSchematic",
        "title": "Block Diagram: Open Schematic"
      }
    ],
    "configuration": {
      "title": "Block Diagram",
      "properties": {
        "blockDiagram.xmlPath": {
          "type": "string",
          "default": "/Users/tobyproctor/Documents/GitHub/verilator/work/example/verilator_example/obj_dir/Vtop.xml",
          "markdownDescription": "Path to the Verilator XML file. Relative paths are resolved from the first workspace folder."
        },
        "blockDiagram.sourceRoot": {
          "type": "string",
          "default": "/Users/tobyproctor/Documents/GitHub/verilator/work/example/verilator_example",
          "markdownDescription": "Root directory for SystemVerilog sources used to resolve XML file entries like top.sv."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
